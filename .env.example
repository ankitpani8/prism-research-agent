# ── Required ──────────────────────────────────────────────────────────────
# Gemini is the primary provider (multimodal + generous free tier).
GEMINI_API_KEY=

# ── Optional: web search ──────────────────────────────────────────────────
# Tavily is the primary search tool. If unset, the repo falls back to the
# keyless DuckDuckGo tool automatically, so the demo still runs.
TAVILY_API_KEY=

# ── Optional: hosted fallbacks (BYOK chain) ───────────────────────────────
# A claude.ai subscription does NOT include API credits (console.anthropic.com).
ANTHROPIC_API_KEY=

# ── Local critic model (Ollama) ───────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434

# ── Optional: tracing (LangSmith) ─────────────────────────────────────────
LANGCHAIN_TRACING_V2=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=prism-research-agent
